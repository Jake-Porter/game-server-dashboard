[Unit]
Description=gs-agent (game server control API)
After=network.target

[Service]
Type=simple
User=gsagent
Group=gsagent
WorkingDirectory=/opt/gs-agent
EnvironmentFile=/etc/gs-agent.env
ExecStart=/opt/gs-agent/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8800
Restart=on-failure
RestartSec=5

ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
